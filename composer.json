{
    "name": "vshemarov/fast-excel-benchmark",
    "description": "Бенчмарк скорости и потребления памяти PHP-библиотек для чтения XLSX",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "ext-zip": "*",
        "ext-xmlreader": "*",
        "ext-mbstring": "*",
        "avadim/fast-excel-reader": "^3.0",
        "avadim/fast-excel-writer": "^6.0",
        "phpoffice/phpspreadsheet": "^5.0",
        "openspout/openspout": "^5.0",
        "shuchkin/simplexlsx": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "fixtures": "php bin/generate-fixtures.php",
        "bench": "php bin/benchmark.php",
        "serve": "php -S 127.0.0.1:8080 -t public"
    }
}
